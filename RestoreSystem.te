#REQUIRE VER 4.0.0
#REQUIRE MINERVA
#REQUIRE KEYS
#REQUIRE SD

# ============================================================
#  RestoreSystem.te
#
#  Restores SYSTEM partition from EmmcHaccGen output.
#  Aggressively nukes existing SYSTEM contents including
#  corrupted files, copies fresh files, and signs saves.
#
#  SETUP:
#    1. On your SD card, create:  sd:/RestoreSystem/SYSTEM/
#    2. Copy your EmmcHaccGen SYSTEM folder contents there
#       so you have:
#         sd:/RestoreSystem/SYSTEM/Contents/registered/
#         sd:/RestoreSystem/SYSTEM/save/
#    3. Place this script at sd:/TegraExplorer/scripts/
#    4. Inject TegraExplorer and run it
# ============================================================

p = println

fatal = {
    color(0xFF0000)
    p("\n[FATAL]", fatalMsg)
    color(0xFFFFFF)
    p("Press any key to exit...")
    pause()
    exit()
}

wait = {
    t = timer()
    while (timer() < (t + tw)) {
        print("Wait for", ((t + tw) - timer()) / 1000, "seconds \r")
    }
}

srcBase = "sd:/RestoreSystem/SYSTEM"

# ---- Preflight checks ----
clear()
color(0x00AAFF)
p("=== SYSTEM Partition Restore ===")
color(0xFFFFFF)
p("")

if (!fsexists(srcBase)) {
    fatal(fatalMsg = "Source not found!\nExpected: sd:/RestoreSystem/SYSTEM/\nPlace your EmmcHaccGen SYSTEM folder there.")
}

if (!fsexists(combinepath(srcBase, "Contents/registered"))) {
    fatal(fatalMsg = "Contents/registered not found in SYSTEM folder!\nIs this a valid EmmcHaccGen output?")
}

if (!fsexists(combinepath(srcBase, "save"))) {
    fatal(fatalMsg = "save/ folder not found in SYSTEM folder!\nIs this a valid EmmcHaccGen output?")
}

color(0x40FF00)
p("Source folder validated:")
color(0xFFFFFF)
p("  sd:/RestoreSystem/SYSTEM/Contents/registered/")
p("  sd:/RestoreSystem/SYSTEM/save/")
p("")

# ---- Choose target ----
useSys = 1

if (emu()) {
    p("EmuMMC detected. Choose target:\n")
    res = menu(["Exit", "SysMMC (internal NAND)", "EmuMMC"], 0)
    if (res == 0) {
        exit()
    }
    if (res == 2) {
        useSys = 0
    }
}.else() {
    p("No emuMMC. Target: SysMMC\n")
    p("Press any key to continue...")
    pause()
}

if (useSys) {
    mount = mountsys
    targetName = "SysMMC"
}.else() {
    mount = mountemu
    targetName = "EmuMMC"
}

# ---- Mount SYSTEM ----
clear()
color(0x00AAFF)
p("=== SYSTEM Partition Restore ===")
color(0xFFFFFF)
p("Target:", targetName)
p("")

print("Mounting SYSTEM... ")
if (mount("SYSTEM")) {
    fatal(fatalMsg = "Failed to mount SYSTEM partition!")
}
color(0x40FF00)
p("OK")
color(0xFFFFFF)
p("")

# ---- Final confirmation ----
color(0xFF0000)
p("WARNING!")
p("This will NUKE all contents of the SYSTEM partition")
p("on", targetName, "and replace them with EmmcHaccGen output.")
p("")
p("Make sure you have a NAND backup before proceeding!")
p("")
color(0xFFFFFF)

wait(tw = 10000)

p("\nPress POWER to start, any other key to exit")
btn = pause()
if (!btn.power) {
    exit()
}

clear()
color(0x00AAFF)
p("=== Restoring SYSTEM ===")
color(0xFFFFFF)
p("Target:", targetName)
p("")
startMs = timer()

# ============================================================
#  Step 1: Backup existing SYSTEM contents (best-effort)
# ============================================================
color(0xFFAA00)
p("[1/5] Backing up current SYSTEM (best-effort)...")
color(0xFFFFFF)

backupDir = "sd:/RestoreSystem/backup"
mkdir("sd:/RestoreSystem")
mkdir(backupDir)

bisRoot = readdir("bis:/")
if (!bisRoot.result) {
    bisRoot.folders.foreach("folder") {
        print("  Backing up folder:", folder, "... ")
        copydir(combinepath("bis:/", folder), backupDir)
        p("done")
    }
    bisRoot.files.foreach("file") {
        print("  Backing up file:", file, "... ")
        copyfile(combinepath("bis:/", file), combinepath(backupDir, file))
        p("done")
    }
}.else() {
    color(0xFFAA00)
    p("  Could not read bis:/ for backup, continuing...")
    color(0xFFFFFF)
}

p("")

# ============================================================
#  Step 2: NUKE - aggressively wipe SYSTEM partition
#
#  Strategy: try multiple methods per item
#    Pass 1: enumerate files individually, delfile each
#    Pass 2: deldir on remaining folders
#    Pass 3: brute-force known system save file names
#    Pass 4: overwrite stubborn files with empty data
# ============================================================
color(0xFF0000)
p("[2/5] NUKING SYSTEM partition...")
color(0xFFFFFF)

nukeErrors = 0

# --- Pass 1: try to delete save files individually ---
color(0xFFAA00)
p("  Pass 1: Deleting save files individually...")
color(0xFFFFFF)

if (fsexists("bis:/save")) {
    saveDir = readdir("bis:/save")
    if (!saveDir.result) {
        # Delete each file one by one
        saveDir.files.foreach("file") {
            fPath = combinepath("bis:/save", file)
            print("    del ", file, "... ")
            r = delfile(fPath)
            if (r) {
                color(0xFF0000)
                p("FAIL")
                color(0xFFFFFF)
                nukeErrors = nukeErrors + 1
            }.else() {
                color(0x40FF00)
                p("ok")
                color(0xFFFFFF)
            }
        }
        # Delete any subdirs inside save
        saveDir.folders.foreach("folder") {
            fPath = combinepath("bis:/save", folder)
            print("    del dir ", folder, "... ")
            r = deldir(fPath)
            if (r) {
                color(0xFF0000)
                p("FAIL")
                color(0xFFFFFF)
                nukeErrors = nukeErrors + 1
            }.else() {
                color(0x40FF00)
                p("ok")
                color(0xFFFFFF)
            }
        }
    }.else() {
        color(0xFFAA00)
        p("    readdir on save/ failed, going to brute-force...")
        color(0xFFFFFF)
    }
}

# --- Pass 2: brute-force delete known system save IDs ---
# If readdir failed or some files survived, try deleting
# by known filenames that exist on every Switch
color(0xFFAA00)
p("  Pass 2: Brute-force known save file names...")
color(0xFFFFFF)

knownSaves = [
    "8000000000000000",
    "8000000000000010",
    "8000000000000011",
    "8000000000000020",
    "8000000000000021",
    "8000000000000025",
    "8000000000000026",
    "8000000000000030",
    "8000000000000031",
    "8000000000000035",
    "8000000000000036",
    "8000000000000037",
    "8000000000000038",
    "8000000000000039",
    "800000000000003B",
    "800000000000003C",
    "800000000000003D",
    "800000000000003E",
    "8000000000000040",
    "8000000000000041",
    "8000000000000042",
    "8000000000000043",
    "8000000000000044",
    "8000000000000045",
    "8000000000000046",
    "8000000000000047",
    "8000000000000048",
    "8000000000000049",
    "800000000000004A",
    "8000000000000050",
    "8000000000000051",
    "8000000000000052",
    "8000000000000053",
    "8000000000000054",
    "8000000000000055",
    "8000000000000060",
    "8000000000000070",
    "8000000000000071",
    "8000000000000072",
    "8000000000000073",
    "8000000000000074",
    "8000000000000075",
    "8000000000000076",
    "8000000000000077",
    "8000000000000078",
    "8000000000000079",
    "800000000000007A",
    "800000000000007B",
    "800000000000007C",
    "8000000000000080",
    "8000000000000081",
    "8000000000000082",
    "8000000000000083",
    "8000000000000084",
    "8000000000000090",
    "8000000000000091",
    "80000000000000A0",
    "80000000000000A1",
    "80000000000000A2",
    "80000000000000B0",
    "80000000000000C0",
    "80000000000000C1",
    "80000000000000C2",
    "80000000000000D0",
    "80000000000000E0",
    "80000000000000E1",
    "80000000000000E2",
    "80000000000000F0",
    "8000000000000100",
    "8000000000000110",
    "8000000000000120",
    "8000000000000121",
    "8000000000000130",
    "8000000000000140",
    "8000000000000150",
    "8000000000000160"
].copy()

bf_del = 0
bf_skip = 0
knownSaves.foreach("sid") {
    sPath = combinepath("bis:/save", sid)
    if (fsexists(sPath)) {
        print("    del ", sid, "... ")
        r = delfile(sPath)
        if (r) {
            color(0xFF0000)
            p("FAIL")
            color(0xFFFFFF)
            nukeErrors = nukeErrors + 1
        }.else() {
            bf_del = bf_del + 1
            color(0x40FF00)
            p("ok")
            color(0xFFFFFF)
        }
    }.else() {
        bf_skip = bf_skip + 1
    }
}
p("    Deleted:", bf_del, " Skipped:", bf_skip)

# --- Pass 3: try deleting save folder itself now ---
color(0xFFAA00)
p("  Pass 3: Removing save/ directory...")
color(0xFFFFFF)

if (fsexists("bis:/save")) {
    print("    deldir bis:/save... ")
    r = deldir("bis:/save")
    if (r) {
        color(0xFF0000)
        p("FAIL - stubborn files remain")
        color(0xFFFFFF)
        nukeErrors = nukeErrors + 1

        # Last resort: overwrite stubborn files with 1-byte data
        color(0xFFAA00)
        p("  Pass 3b: Overwriting stubborn files with empty data...")
        color(0xFFFFFF)

        stubSave = readdir("bis:/save")
        if (!stubSave.result) {
            stubSave.files.foreach("sf") {
                sfPath = combinepath("bis:/save", sf)
                print("    overwrite ", sf, "... ")
                writefile(sfPath, ["BYTE[]", 0])
                delfile(sfPath)
                if (fsexists(sfPath)) {
                    color(0xFF0000)
                    p("still stuck")
                    color(0xFFFFFF)
                }.else() {
                    color(0x40FF00)
                    p("ok")
                    color(0xFFFFFF)
                }
            }
        }

        # Final attempt
        deldir("bis:/save")
    }.else() {
        color(0x40FF00)
        p("gone")
        color(0xFFFFFF)
    }
}

# --- Pass 4: nuke everything else on the partition ---
color(0xFFAA00)
p("  Pass 4: Cleaning remaining items...")
color(0xFFFFFF)

bisRoot2 = readdir("bis:/")
if (!bisRoot2.result) {
    bisRoot2.folders.foreach("folder") {
        fullPath = combinepath("bis:/", folder)
        print("    del folder:", folder, "... ")
        deldir(fullPath)
        if (fsexists(fullPath)) {
            color(0xFF0000)
            p("FAIL")
            color(0xFFFFFF)
        }.else() {
            color(0x40FF00)
            p("gone")
            color(0xFFFFFF)
        }
    }
    bisRoot2.files.foreach("file") {
        fullPath = combinepath("bis:/", file)
        print("    del file:", file, "... ")
        delfile(fullPath)
        if (fsexists(fullPath)) {
            color(0xFF0000)
            p("FAIL")
            color(0xFFFFFF)
        }.else() {
            color(0x40FF00)
            p("gone")
            color(0xFFFFFF)
        }
    }
}

# Final verification
p("")
print("  Final check... ")
finalCheck = readdir("bis:/")
if (!finalCheck.result) {
    leftover = finalCheck.files.len() + finalCheck.folders.len()
    if (leftover == 0) {
        color(0x40FF00)
        p("PARTITION IS CLEAN")
        color(0xFFFFFF)
    }.else() {
        color(0xFFAA00)
        p(leftover, "items could not be removed")
        p("  Will overwrite them during copy step")
        color(0xFFFFFF)
    }
}.else() {
    p("readdir failed but continuing with copy...")
}

p("")

# ============================================================
#  Step 3: Copy EmmcHaccGen SYSTEM contents
# ============================================================
color(0xFFAA00)
p("[3/5] Copying EmmcHaccGen SYSTEM contents...")
color(0xFFFFFF)

srcRoot = readdir(srcBase)
if (srcRoot.result) {
    fatal(fatalMsg = "Cannot read source: " + srcBase)
}

# Copy all folders
srcRoot.folders.foreach("folder") {
    srcPath = combinepath(srcBase, folder)
    print("  Copying folder:", folder, "... ")
    if (copydir(srcPath, "bis:/")) {
        fatal(fatalMsg = "Failed to copy folder: " + folder)
    }
    color(0x40FF00)
    p("OK")
    color(0xFFFFFF)
}

# Copy all root-level files
srcRoot.files.foreach("file") {
    srcPath = combinepath(srcBase, file)
    dstPath = combinepath("bis:/", file)
    print("  Copying file:", file, "... ")
    if (copyfile(srcPath, dstPath)) {
        fatal(fatalMsg = "Failed to copy file: " + file)
    }
    color(0x40FF00)
    p("OK")
    color(0xFFFFFF)
}

p("")

# ============================================================
#  Step 4: Sign save 8000000000000120
# ============================================================
color(0xFFAA00)
p("[4/5] Signing save 8000000000000120...")
color(0xFFFFFF)

savePath120 = "bis:/save/8000000000000120"
if (fsexists(savePath120)) {
    print("  Reading and signing... ")
    sav120 = readsave(savePath120)
    if (sav120.commit()) {
        fatal(fatalMsg = "Failed to sign save 8000000000000120!\nThis save is critical for boot.")
    }
    sav120 = 0
    color(0x40FF00)
    p("SIGNED OK")
    color(0xFFFFFF)
}.else() {
    fatal(fatalMsg = "save 8000000000000120 not found after copy!\nSomething went wrong during file copy.")
}

p("")

# ============================================================
#  Step 5: Sign save 8000000000000000
# ============================================================
color(0xFFAA00)
p("[5/5] Signing save 8000000000000000...")
color(0xFFFFFF)

savePath000 = "bis:/save/8000000000000000"
if (fsexists(savePath000)) {
    print("  Reading and signing... ")
    sav000 = readsave(savePath000)
    if (sav000.commit()) {
        fatal(fatalMsg = "Failed to sign save 8000000000000000!\nThis is the FS save index and is required for boot.")
    }
    sav000 = 0
    color(0x40FF00)
    p("SIGNED OK")
    color(0xFFFFFF)
}.else() {
    fatal(fatalMsg = "save 8000000000000000 not found after copy!\nSomething went wrong during file copy.")
}

p("")

# ============================================================
#  Done
# ============================================================
elapsed = (timer() - startMs) / 1000

color(0x40FF00)
p("=========================================")
p("  RESTORE COMPLETE!")
p("=========================================")
color(0xFFFFFF)
p("")
p("Time taken:", elapsed, "seconds")
p("Target:", targetName)
p("")
p("Both saves signed successfully:")
p("  8000000000000120 (system save index)")
p("  8000000000000000 (FS save index)")
p("")
p("Backup of old files: sd:/RestoreSystem/backup/")
p("")

if (nukeErrors > 0) {
    color(0xFFAA00)
    p("Note:", nukeErrors, "files could not be deleted during nuke.")
    p("They were overwritten by the new files. This is usually fine.")
    color(0xFFFFFF)
    p("")
}

color(0x40FF00)
p("Next steps:")
color(0xFFFFFF)
p("  1. Exit TegraExplorer")
p("  2. Boot via Hekate -> Launch -> CFW or Stock")
p("  3. If booting emuMMC, create a FRESH one from")
p("     the now-fixed sysNAND instead of reusing the")
p("     old corrupted copy")
p("")
p("If STILL failing after this, the partition FAT table")
p("itself may be corrupted. In that case use Hekate:")
p("  Tools -> USB Tools -> eMMC RAW GPP")
p("  Mount on PC and format the SYSTEM partition from")
p("  there, then re-run this script.")
p("")
p("Press any key to exit")
pause()
